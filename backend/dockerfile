# Use official Bun image with specific version
FROM oven/bun:1.3.5 as builder

# Set working directory
WORKDIR /app

# Copy only package files for better layer caching
COPY package.json bun.lockb ./

# Install dependencies
RUN bun install --frozen-lockfile

# Copy source code
COPY . .

# Build stage (for production, if needed)
FROM oven/bun:1.3.5

# Set working directory
WORKDIR /app

# Set environment variables
ENV NODE_ENV=production \
    PORT=8085 \
    DATABASE_URL=postgresql://ai-camera:ai-camera@localhost:5443/aiPostgres

# Create non-root user for security
RUN groupadd -r bunapp && useradd -r -g bunapp bunapp

# Copy from builder stage
COPY --from=builder --chown=bunapp:bunapp /app .

# Expose port
EXPOSE 8085

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD bun run --eval "const response = await fetch('http://localhost:8085'); console.log(response.status === 200 ? 'OK' : 'FAIL'); process.exit(response.status === 200 ? 0 : 1);" || exit 1

# Switch to non-root user
USER bunapp

# Default command
CMD ["bun", "index.ts"]