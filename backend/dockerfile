# Use official Bun image with specific version
FROM oven/bun:1.3.5 as builder

WORKDIR /app

COPY package.json bun.lock ./

RUN bun install --frozen-lockfile

COPY . .

RUN bunx prisma generate

FROM oven/bun:1.3.5

WORKDIR /app

ENV NODE_ENV=production \
    PORT=8085 \
    DATABASE_URL=postgresql://ai-camera:ai-camera@localhost:5443/aiPostgres

# ✅ FIXED: added curl so healthcheck works
RUN apt-get update && apt-get install -y postgresql-client curl && rm -rf /var/lib/apt/lists/*

RUN groupadd -r bunapp && useradd -r -g bunapp bunapp

COPY --from=builder --chown=bunapp:bunapp /app .

COPY --chown=bunapp:bunapp start.sh /app/start.sh
RUN chmod +x /app/start.sh

EXPOSE 8085

# ✅ FIXED: healthcheck now checks the app, not postgres
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8085/ || exit 1

USER bunapp

CMD ["/app/start.sh"]