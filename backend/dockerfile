# Use official Bun image with specific version
FROM oven/bun:1.3.5 as builder

# Set working directory
WORKDIR /app

# Copy only package files for better layer caching
COPY package.json bun.lockb ./

# Install dependencies
RUN bun install --frozen-lockfile

# Copy source code
COPY . .

# Build stage (for production, if needed)
FROM oven/bun:1.3.5

# Set working directory
WORKDIR /app

# Set environment variables
ENV NODE_ENV=production \
    PORT=8085 \
    DATABASE_URL=postgresql://ai-camera:ai-camera@localhost:5443/aiPostgres

# Install postgresql-client for health checks and database connection
RUN apt-get update && apt-get install -y postgresql-client && rm -rf /var/lib/apt/lists/*

# Create non-root user for security
RUN groupadd -r bunapp && useradd -r -g bunapp bunapp

# Copy from builder stage
COPY --from=builder --chown=bunapp:bunapp /app .

# Copy startup script
COPY --chown=bunapp:bunapp start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Expose port
EXPOSE 8085

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD pg_isready -h postgres -U ${DB_USER:-ai-camera} -d ${DB_NAME:-aiPostgres} || exit 1

# Switch to non-root user
USER bunapp

# Use startup script
CMD ["/app/start.sh"]