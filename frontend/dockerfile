# Multi-stage build for frontend
# Stage 1: Builder
FROM oven/bun:1.3.5 as builder

WORKDIR /app

# Copy package files
COPY package.json bun.lockb ./

# Install dependencies
RUN bun install --frozen-lockfile

# Copy source code
COPY . .

# Build the frontend
RUN bun run build

# Stage 2: Runtime
FROM oven/bun:1.3.5

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# Create non-root user for security
RUN groupadd -r webuser && useradd -r -g webuser webuser

# Copy built files from builder
COPY --from=builder --chown=webuser:webuser /app/build ./build
COPY --from=builder --chown=webuser:webuser /app/node_modules ./node_modules
COPY --from=builder --chown=webuser:webuser /app/package.json ./package.json

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD bun run --eval "const res = await fetch('http://localhost:3000'); res.status === 200 ? process.exit(0) : process.exit(1);"

# Switch to non-root user
USER webuser

# Start server
CMD ["bun", "run", "preview"]
